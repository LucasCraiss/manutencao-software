{"ast":null,"code":"import ProdutoService from '../services/ProdutoService';\nconst produtoVazio = () => ({\n  nome: '',\n  descricao: '',\n  categoria: '',\n  quantidade: 0,\n  quantidadeMinima: 5,\n  preco: null,\n  unidade: 'un',\n  localizacao: '',\n  fornecedor: ''\n});\nexport default {\n  name: 'FormProduto',\n  props: {\n    id: {\n      type: [String, Number],\n      default: null\n    }\n  },\n  data() {\n    return {\n      produto: produtoVazio(),\n      erros: {},\n      mensagem: '',\n      tipoMensagem: 'success',\n      salvando: false\n    };\n  },\n  computed: {\n    modoEdicao() {\n      return !!this.id;\n    }\n  },\n  created() {\n    if (this.modoEdicao) this.carregarProduto();\n  },\n  methods: {\n    async carregarProduto() {\n      try {\n        const resp = await ProdutoService.getById(this.id);\n        this.produto = resp.data;\n      } catch {\n        this.exibirMensagem('Erro ao carregar produto.', 'danger');\n      }\n    },\n    validar() {\n      this.erros = {};\n      if (!this.produto.nome) this.erros.nome = 'Nome é obrigatório.';\n      if (this.produto.quantidade < 0) this.erros.quantidade = 'Quantidade não pode ser negativa.';\n      if (this.produto.quantidadeMinima < 0) this.erros.quantidadeMinima = 'Estoque mínimo inválido.';\n      return Object.keys(this.erros).length === 0;\n    },\n    async salvarProduto() {\n      if (!this.validar()) return;\n      this.salvando = true;\n      try {\n        if (this.modoEdicao) {\n          await ProdutoService.update(this.id, this.produto);\n          this.exibirMensagem('Produto atualizado com sucesso!', 'success');\n        } else {\n          await ProdutoService.create(this.produto);\n          this.exibirMensagem('Produto cadastrado com sucesso!', 'success');\n          this.limparFormulario();\n        }\n      } catch {\n        this.exibirMensagem('Erro ao salvar produto.', 'danger');\n      } finally {\n        this.salvando = false;\n      }\n    },\n    limparFormulario() {\n      this.produto = produtoVazio();\n      this.erros = {};\n    },\n    exibirMensagem(texto, tipo = 'success') {\n      this.mensagem = texto;\n      this.tipoMensagem = tipo;\n      setTimeout(() => {\n        this.mensagem = '';\n      }, 4000);\n    }\n  }\n};","map":{"version":3,"names":["ProdutoService","produtoVazio","nome","descricao","categoria","quantidade","quantidadeMinima","preco","unidade","localizacao","fornecedor","name","props","id","type","String","Number","default","data","produto","erros","mensagem","tipoMensagem","salvando","computed","modoEdicao","created","carregarProduto","methods","resp","getById","exibirMensagem","validar","Object","keys","length","salvarProduto","update","create","limparFormulario","texto","tipo","setTimeout"],"sources":["C:\\Users\\Lucas Crais\\manuntencao-software\\frontend\\src\\components\\FormProduto.vue"],"sourcesContent":["<template>\n  <div>\n    <div class=\"d-flex align-items-center mb-3\">\n      <router-link to=\"/produtos\" class=\"btn btn-outline-secondary me-3\">\n        <i class=\"bi bi-arrow-left\"></i>\n      </router-link>\n      <h2>\n        <i class=\"bi bi-box me-2\"></i>\n        {{ modoEdicao ? 'Editar Produto' : 'Novo Produto' }}\n      </h2>\n    </div>\n\n    <div v-if=\"mensagem\" :class=\"`alert alert-${tipoMensagem}`\">{{ mensagem }}</div>\n\n    <div class=\"card shadow-sm\">\n      <div class=\"card-body\">\n        <form @submit.prevent=\"salvarProduto\" novalidate>\n          <div class=\"row g-3\">\n\n            <!-- Nome -->\n            <div class=\"col-md-8\">\n              <label class=\"form-label fw-bold\">Nome do Produto *</label>\n              <input\n                v-model.trim=\"produto.nome\"\n                type=\"text\"\n                class=\"form-control\"\n                :class=\"{ 'is-invalid': erros.nome }\"\n                placeholder=\"Ex: Notebook Dell Inspiron\"\n                maxlength=\"150\"\n              />\n              <div v-if=\"erros.nome\" class=\"invalid-feedback\">{{ erros.nome }}</div>\n            </div>\n\n            <!-- Categoria -->\n            <div class=\"col-md-4\">\n              <label class=\"form-label fw-bold\">Categoria</label>\n              <select v-model=\"produto.categoria\" class=\"form-select\">\n                <option value=\"\">Selecione...</option>\n                <option>Eletrônicos</option>\n                <option>Informática</option>\n                <option>Escritório</option>\n                <option>Ferramentas</option>\n                <option>Higiene</option>\n                <option>Alimentação</option>\n                <option>Outros</option>\n              </select>\n            </div>\n\n            <!-- Descrição -->\n            <div class=\"col-12\">\n              <label class=\"form-label fw-bold\">Descrição</label>\n              <textarea\n                v-model.trim=\"produto.descricao\"\n                class=\"form-control\"\n                rows=\"2\"\n                placeholder=\"Descrição detalhada do produto...\"\n                maxlength=\"500\"\n              ></textarea>\n            </div>\n\n            <!-- Quantidade atual -->\n            <div class=\"col-md-3\">\n              <label class=\"form-label fw-bold\">Quantidade em Estoque *</label>\n              <input\n                v-model.number=\"produto.quantidade\"\n                type=\"number\"\n                class=\"form-control\"\n                :class=\"{ 'is-invalid': erros.quantidade }\"\n                min=\"0\"\n              />\n              <div v-if=\"erros.quantidade\" class=\"invalid-feedback\">{{ erros.quantidade }}</div>\n            </div>\n\n            <!-- Quantidade mínima -->\n            <div class=\"col-md-3\">\n              <label class=\"form-label fw-bold\">Estoque Mínimo *</label>\n              <input\n                v-model.number=\"produto.quantidadeMinima\"\n                type=\"number\"\n                class=\"form-control\"\n                :class=\"{ 'is-invalid': erros.quantidadeMinima }\"\n                min=\"0\"\n              />\n              <div v-if=\"erros.quantidadeMinima\" class=\"invalid-feedback\">{{ erros.quantidadeMinima }}</div>\n            </div>\n\n            <!-- Preço -->\n            <div class=\"col-md-3\">\n              <label class=\"form-label fw-bold\">Preço (R$)</label>\n              <div class=\"input-group\">\n                <span class=\"input-group-text\">R$</span>\n                <input\n                  v-model.number=\"produto.preco\"\n                  type=\"number\"\n                  class=\"form-control\"\n                  step=\"0.01\"\n                  min=\"0\"\n                  placeholder=\"0,00\"\n                />\n              </div>\n            </div>\n\n            <!-- Unidade -->\n            <div class=\"col-md-3\">\n              <label class=\"form-label fw-bold\">Unidade</label>\n              <select v-model=\"produto.unidade\" class=\"form-select\">\n                <option value=\"un\">Unidade (un)</option>\n                <option value=\"kg\">Quilograma (kg)</option>\n                <option value=\"l\">Litro (l)</option>\n                <option value=\"cx\">Caixa (cx)</option>\n                <option value=\"pc\">Pacote (pc)</option>\n              </select>\n            </div>\n\n            <!-- Localização no estoque -->\n            <div class=\"col-md-6\">\n              <label class=\"form-label fw-bold\">Localização no Estoque</label>\n              <input\n                v-model.trim=\"produto.localizacao\"\n                type=\"text\"\n                class=\"form-control\"\n                placeholder=\"Ex: Prateleira A3, Depósito 2...\"\n              />\n            </div>\n\n            <!-- Fornecedor -->\n            <div class=\"col-md-6\">\n              <label class=\"form-label fw-bold\">Fornecedor</label>\n              <input\n                v-model.trim=\"produto.fornecedor\"\n                type=\"text\"\n                class=\"form-control\"\n                placeholder=\"Nome do fornecedor...\"\n              />\n            </div>\n\n          </div>\n\n          <hr class=\"my-4\">\n\n          <div class=\"d-flex gap-2\">\n            <button type=\"submit\" class=\"btn btn-primary\" :disabled=\"salvando\">\n              <span v-if=\"salvando\" class=\"spinner-border spinner-border-sm me-2\"></span>\n              <i v-else class=\"bi bi-check-lg me-1\"></i>\n              {{ modoEdicao ? 'Salvar Alterações' : 'Cadastrar Produto' }}\n            </button>\n            <button type=\"button\" class=\"btn btn-outline-secondary\" @click=\"limparFormulario\">\n              <i class=\"bi bi-x-lg me-1\"></i>Limpar\n            </button>\n            <router-link to=\"/produtos\" class=\"btn btn-outline-danger ms-auto\">\n              Cancelar\n            </router-link>\n          </div>\n\n        </form>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport ProdutoService from '../services/ProdutoService'\n\nconst produtoVazio = () => ({\n  nome: '',\n  descricao: '',\n  categoria: '',\n  quantidade: 0,\n  quantidadeMinima: 5,\n  preco: null,\n  unidade: 'un',\n  localizacao: '',\n  fornecedor: ''\n})\n\nexport default {\n  name: 'FormProduto',\n  props: {\n    id: { type: [String, Number], default: null }\n  },\n  data () {\n    return {\n      produto: produtoVazio(),\n      erros: {},\n      mensagem: '',\n      tipoMensagem: 'success',\n      salvando: false\n    }\n  },\n  computed: {\n    modoEdicao () {\n      return !!this.id\n    }\n  },\n  created () {\n    if (this.modoEdicao) this.carregarProduto()\n  },\n  methods: {\n    async carregarProduto () {\n      try {\n        const resp = await ProdutoService.getById(this.id)\n        this.produto = resp.data\n      } catch {\n        this.exibirMensagem('Erro ao carregar produto.', 'danger')\n      }\n    },\n    validar () {\n      this.erros = {}\n      if (!this.produto.nome) this.erros.nome = 'Nome é obrigatório.'\n      if (this.produto.quantidade < 0) this.erros.quantidade = 'Quantidade não pode ser negativa.'\n      if (this.produto.quantidadeMinima < 0) this.erros.quantidadeMinima = 'Estoque mínimo inválido.'\n      return Object.keys(this.erros).length === 0\n    },\n    async salvarProduto () {\n      if (!this.validar()) return\n      this.salvando = true\n      try {\n        if (this.modoEdicao) {\n          await ProdutoService.update(this.id, this.produto)\n          this.exibirMensagem('Produto atualizado com sucesso!', 'success')\n        } else {\n          await ProdutoService.create(this.produto)\n          this.exibirMensagem('Produto cadastrado com sucesso!', 'success')\n          this.limparFormulario()\n        }\n      } catch {\n        this.exibirMensagem('Erro ao salvar produto.', 'danger')\n      } finally {\n        this.salvando = false\n      }\n    },\n    limparFormulario () {\n      this.produto = produtoVazio()\n      this.erros = {}\n    },\n    exibirMensagem (texto, tipo = 'success') {\n      this.mensagem = texto\n      this.tipoMensagem = tipo\n      setTimeout(() => { this.mensagem = '' }, 4000)\n    }\n  }\n}\n</script>\n"],"mappings":"AAiKA,OAAOA,cAAa,MAAO,4BAA2B;AAEtD,MAAMC,YAAW,GAAIA,CAAA,MAAO;EAC1BC,IAAI,EAAE,EAAE;EACRC,SAAS,EAAE,EAAE;EACbC,SAAS,EAAE,EAAE;EACbC,UAAU,EAAE,CAAC;EACbC,gBAAgB,EAAE,CAAC;EACnBC,KAAK,EAAE,IAAI;EACXC,OAAO,EAAE,IAAI;EACbC,WAAW,EAAE,EAAE;EACfC,UAAU,EAAE;AACd,CAAC;AAED,eAAe;EACbC,IAAI,EAAE,aAAa;EACnBC,KAAK,EAAE;IACLC,EAAE,EAAE;MAAEC,IAAI,EAAE,CAACC,MAAM,EAAEC,MAAM,CAAC;MAAEC,OAAO,EAAE;IAAK;EAC9C,CAAC;EACDC,IAAGA,CAAA,EAAK;IACN,OAAO;MACLC,OAAO,EAAElB,YAAY,CAAC,CAAC;MACvBmB,KAAK,EAAE,CAAC,CAAC;MACTC,QAAQ,EAAE,EAAE;MACZC,YAAY,EAAE,SAAS;MACvBC,QAAQ,EAAE;IACZ;EACF,CAAC;EACDC,QAAQ,EAAE;IACRC,UAASA,CAAA,EAAK;MACZ,OAAO,CAAC,CAAC,IAAI,CAACZ,EAAC;IACjB;EACF,CAAC;EACDa,OAAMA,CAAA,EAAK;IACT,IAAI,IAAI,CAACD,UAAU,EAAE,IAAI,CAACE,eAAe,CAAC;EAC5C,CAAC;EACDC,OAAO,EAAE;IACP,MAA