{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport ProdutoService from '../services/ProdutoService';\nexport default {\n  name: 'ListaProdutos',\n  data() {\n    return {\n      produtos: [],\n      termoBusca: '',\n      carregando: false,\n      mensagem: '',\n      tipoMensagem: 'success',\n      produtoParaExcluir: null\n    };\n  },\n  computed: {\n    produtosEstoqueBaixo() {\n      return this.produtos.filter(p => p.quantidade < p.quantidadeMinima).length;\n    }\n  },\n  created() {\n    this.carregarProdutos();\n  },\n  methods: {\n    async carregarProdutos() {\n      this.carregando = true;\n      try {\n        const resp = await ProdutoService.getAll();\n        this.produtos = resp.data;\n      } catch (err) {\n        this.exibirMensagem('Erro ao carregar produtos.', 'danger');\n      } finally {\n        this.carregando = false;\n      }\n    },\n    async buscarProdutos() {\n      this.carregando = true;\n      try {\n        const resp = await ProdutoService.getAll(this.termoBusca);\n        this.produtos = resp.data;\n      } catch (err) {\n        this.exibirMensagem('Erro ao buscar produtos.', 'danger');\n      } finally {\n        this.carregando = false;\n      }\n    },\n    limparBusca() {\n      this.termoBusca = '';\n      this.carregarProdutos();\n    },\n    confirmarExclusao(produto) {\n      this.produtoParaExcluir = produto;\n    },\n    async excluirProduto(id) {\n      try {\n        await ProdutoService.delete(id);\n        this.produtos = this.produtos.filter(p => p.id !== id);\n        this.exibirMensagem('Produto excluído com sucesso.', 'success');\n      } catch (err) {\n        this.exibirMensagem('Erro ao excluir produto.', 'danger');\n      } finally {\n        this.produtoParaExcluir = null;\n      }\n    },\n    formatarPreco(valor) {\n      if (!valor) return '—';\n      return Number(valor).toLocaleString('pt-BR', {\n        style: 'currency',\n        currency: 'BRL'\n      });\n    },\n    exibirMensagem(texto, tipo = 'success') {\n      this.mensagem = texto;\n      this.tipoMensagem = tipo;\n      setTimeout(() => {\n        this.mensagem = '';\n      }, 4000);\n    }\n  }\n};","map":{"version":3,"names":["ProdutoService","name","data","produtos","termoBusca","carregando","mensagem","tipoMensagem","produtoParaExcluir","computed","produtosEstoqueBaixo","filter","p","quantidade","quantidadeMinima","length","created","carregarProdutos","methods","resp","getAll","err","exibirMensagem","buscarProdutos","limparBusca","confirmarExclusao","produto","excluirProduto","id","delete","formatarPreco","valor","Number","toLocaleString","style","currency","texto","tipo","setTimeout"],"sources":["C:\\Users\\Lucas Crais\\manuntencao-software\\frontend\\src\\components\\ListaProdutos.vue"],"sourcesContent":["<template>\n  <div>\n    <div class=\"d-flex justify-content-between align-items-center mb-3\">\n      <h2><i class=\"bi bi-box-seam me-2\"></i>Produtos em Estoque</h2>\n      <router-link to=\"/produtos/novo\" class=\"btn btn-primary\">\n        <i class=\"bi bi-plus-lg me-1\"></i>Novo Produto\n      </router-link>\n    </div>\n\n    <!-- Barra de busca -->\n    <div class=\"input-group mb-3\">\n      <span class=\"input-group-text\"><i class=\"bi bi-search\"></i></span>\n      <input\n        v-model=\"termoBusca\"\n        type=\"text\"\n        class=\"form-control\"\n        placeholder=\"Buscar produto por nome...\"\n        @keyup.enter=\"buscarProdutos\"\n      />\n      <button class=\"btn btn-outline-secondary\" @click=\"buscarProdutos\">Buscar</button>\n      <button class=\"btn btn-outline-danger\" @click=\"limparBusca\">Limpar</button>\n    </div>\n\n    <!-- Alertas de feedback -->\n    <div v-if=\"mensagem\" :class=\"`alert alert-${tipoMensagem} alert-dismissible`\" role=\"alert\">\n      {{ mensagem }}\n      <button type=\"button\" class=\"btn-close\" @click=\"mensagem = ''\"></button>\n    </div>\n\n    <!-- Tabela de produtos -->\n    <div v-if=\"carregando\" class=\"text-center py-5\">\n      <div class=\"spinner-border text-primary\" role=\"status\">\n        <span class=\"visually-hidden\">Carregando...</span>\n      </div>\n    </div>\n\n    <div v-else-if=\"produtos.length === 0\" class=\"alert alert-info\">\n      <i class=\"bi bi-info-circle me-2\"></i>\n      Nenhum produto encontrado. <router-link to=\"/produtos/novo\">Cadastre o primeiro!</router-link>\n    </div>\n\n    <div v-else>\n      <!-- Alerta de estoque baixo -->\n      <div v-if=\"produtosEstoqueBaixo > 0\" class=\"alert alert-warning mb-3\">\n        <i class=\"bi bi-exclamation-triangle me-2\"></i>\n        <strong>{{ produtosEstoqueBaixo }} produto(s)</strong> com estoque abaixo do mínimo.\n      </div>\n\n      <div class=\"table-responsive\">\n        <table class=\"table table-hover table-striped align-middle\">\n          <thead class=\"table-dark\">\n            <tr>\n              <th>#</th>\n              <th>Nome</th>\n              <th>Categoria</th>\n              <th>Qtd. em Estoque</th>\n              <th>Qtd. Mínima</th>\n              <th>Preço (R$)</th>\n              <th>Status</th>\n              <th class=\"text-center\">Ações</th>\n            </tr>\n          </thead>\n          <tbody>\n            <tr\n              v-for=\"produto in produtos\"\n              :key=\"produto.id\"\n              :class=\"{ 'table-danger': produto.quantidade < produto.quantidadeMinima }\"\n            >\n              <td>{{ produto.id }}</td>\n              <td>\n                <strong>{{ produto.nome }}</strong>\n                <small v-if=\"produto.descricao\" class=\"d-block text-muted\">{{ produto.descricao }}</small>\n              </td>\n              <td>\n                <span class=\"badge bg-secondary\">{{ produto.categoria || '—' }}</span>\n              </td>\n              <td>{{ produto.quantidade }}</td>\n              <td>{{ produto.quantidadeMinima }}</td>\n              <td>{{ formatarPreco(produto.preco) }}</td>\n              <td>\n                <span\n                  class=\"badge\"\n                  :class=\"produto.quantidade >= produto.quantidadeMinima ? 'bg-success' : 'bg-danger'\"\n                >\n                  {{ produto.quantidade >= produto.quantidadeMinima ? 'OK' : 'Baixo' }}\n                </span>\n              </td>\n              <td class=\"text-center\">\n                <router-link\n                  :to=\"`/produtos/${produto.id}`\"\n                  class=\"btn btn-sm btn-info me-1\"\n                  title=\"Visualizar\"\n                >\n                  <i class=\"bi bi-eye\"></i>\n                </router-link>\n                <router-link\n                  :to=\"`/produtos/${produto.id}/editar`\"\n                  class=\"btn btn-sm btn-warning me-1\"\n                  title=\"Editar\"\n                >\n                  <i class=\"bi bi-pencil\"></i>\n                </router-link>\n                <button\n                  class=\"btn btn-sm btn-danger\"\n                  title=\"Excluir\"\n                  @click=\"confirmarExclusao(produto)\"\n                >\n                  <i class=\"bi bi-trash\"></i>\n                </button>\n              </td>\n            </tr>\n          </tbody>\n        </table>\n      </div>\n\n      <small class=\"text-muted\">Total: {{ produtos.length }} produto(s)</small>\n    </div>\n\n    <!-- Modal de confirmação de exclusão -->\n    <div v-if=\"produtoParaExcluir\" class=\"modal d-block\" tabindex=\"-1\" style=\"background:rgba(0,0,0,0.5)\">\n      <div class=\"modal-dialog\">\n        <div class=\"modal-content\">\n          <div class=\"modal-header\">\n            <h5 class=\"modal-title\">Confirmar Exclusão</h5>\n          </div>\n          <div class=\"modal-body\">\n            Tem certeza que deseja excluir o produto <strong>{{ produtoParaExcluir.nome }}</strong>?\n          </div>\n          <div class=\"modal-footer\">\n            <button class=\"btn btn-secondary\" @click=\"produtoParaExcluir = null\">Cancelar</button>\n            <button class=\"btn btn-danger\" @click=\"excluirProduto(produtoParaExcluir.id)\">Excluir</button>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport ProdutoService from '../services/ProdutoService'\n\nexport default {\n  name: 'ListaProdutos',\n  data () {\n    return {\n      produtos: [],\n      termoBusca: '',\n      carregando: false,\n      mensagem: '',\n      tipoMensagem: 'success',\n      produtoParaExcluir: null\n    }\n  },\n  computed: {\n    produtosEstoqueBaixo () {\n      return this.produtos.filter(p => p.quantidade < p.quantidadeMinima).length\n    }\n  },\n  created () {\n    this.carregarProdutos()\n  },\n  methods: {\n    async carregarProdutos () {\n      this.carregando = true\n      try {\n        const resp = await ProdutoService.getAll()\n        this.produtos = resp.data\n      } catch (err) {\n        this.exibirMensagem('Erro ao carregar produtos.', 'danger')\n      } finally {\n        this.carregando = false\n      }\n    },\n    async buscarProdutos () {\n      this.carregando = true\n      try {\n        const resp = await ProdutoService.getAll(this.termoBusca)\n        this.produtos = resp.data\n      } catch (err) {\n        this.exibirMensagem('Erro ao buscar produtos.', 'danger')\n      } finally {\n        this.carregando = false\n      }\n    },\n    limparBusca () {\n      this.termoBusca = ''\n      this.carregarProdutos()\n    },\n    confirmarExclusao (produto) {\n      this.produtoParaExcluir = produto\n    },\n    async excluirProduto (id) {\n      try {\n        await ProdutoService.delete(id)\n        this.produtos = this.produtos.filter(p => p.id !== id)\n        this.exibirMensagem('Produto excluído com sucesso.', 'success')\n      } catch (err) {\n        this.exibirMensagem('Erro ao excluir produto.', 'danger')\n      } finally {\n        this.produtoParaExcluir = null\n      }\n    },\n    formatarPreco (valor) {\n      if (!valor) return '—'\n      return Number(valor).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' })\n    },\n    exibirMensagem (texto, tipo = 'success') {\n      this.mensagem = texto\n      this.tipoMensagem = tipo\n      setTimeout(() => { this.mensagem = '' }, 4000)\n    }\n  }\n}\n</script>\n"],"mappings":";;AA2IA,OAAOA,cAAa,MAAO,4BAA2B;AAEtD,eAAe;EACbC,IAAI,EAAE,eAAe;EACrBC,IAAGA,CAAA,EAAK;IACN,OAAO;MACLC,QAAQ,EAAE,EAAE;MACZC,UAAU,EAAE,EAAE;MACdC,UAAU,EAAE,KAAK;MACjBC,QAAQ,EAAE,EAAE;MACZC,YAAY,EAAE,SAAS;MACvBC,kBAAkB,EAAE;IACtB;EACF,CAAC;EACDC,QAAQ,EAAE;IACRC,oBAAmBA,CAAA,EAAK;MACtB,OAAO,IAAI,CAACP,QAAQ,CAACQ,MAAM,CAACC,CAAA,IAAKA,CAAC,CAACC,UAAS,GAAID,CAAC,CAACE,gBAAgB,CAAC,CAACC,MAAK;IAC3E;EACF,CAAC;EACDC,OAAMA,CAAA,EAAK;IACT,IAAI,CAACC,gBAAgB,CAAC;EACxB,CAAC;EACDC,OAAO,EAAE;IACP,MAAMD,gBAAeA,CAAA,EAAK;MACxB,IAAI,CAACZ,UAAS,GAAI,IAAG;MACrB,IAAI;QACF,MAAMc,IAAG,GAAI,MAAMnB,cAAc,CAACoB,MAAM,CAAC;QACzC,IAAI,CAACjB,QAAO,GAAIgB,IAAI,CAACjB,IAAG;MAC1B,EAAE,OAAOmB,GAAG,EAAE;QACZ,IAAI,CAACC,cAAc,CAAC,4BAA4B,EAAE,QAAQ;MAC5D,UAAU;QACR,IAAI,CAACjB,UAAS,GAAI,KAAI;MACxB;IACF,CAAC;IACD,MAAMkB,cAAaA,CAAA,EAAK;MACtB,IAAI,CAAClB,UAAS,GAAI,IAAG;MACrB,IAAI;QACF,MAAMc,IAAG,GAAI,MAAMnB,cAAc,CAACoB,MAAM,CAAC,IAAI,CAAChB,UAAU;QACxD,IAAI,CAACD,QAAO,GAAIgB,IAAI,CAACjB,IAAG;MAC1B,EAAE,OAAOmB,GAAG,EAAE;QACZ,IAAI,CAACC,cAAc,CAAC,0BAA0B,EAAE,QAAQ;MAC1D,UAAU;QACR,IAAI,CAACjB,UAAS,GAAI,KAAI;MACxB;IACF,CAAC;IACDmB,WAAUA,CAAA,EAAK;MACb,IAAI,CAACpB,UAAS,GAAI,EAAC;MACnB,IAAI,CAACa,gBAAgB,CAAC;IACxB,CAAC;IACDQ,iBAAgBA,CAAGC,OAAO,EAAE;MAC1B,IAAI,CAAClB,kBAAiB,GAAIkB,OAAM;IAClC,CAAC;IACD,MAAMC,cAAaA,CAAGC,EAAE,EAAE;MACxB,IAAI;QACF,MAAM5B,cAAc,CAAC6B,MAAM,CAACD,EAAE;QAC9B,IAAI,CAACzB,QAAO,GAAI,IAAI,CAACA,QAAQ,CAACQ,MAAM,CAACC,CAAA,IAAKA,CAAC,CAACgB,EAAC,KAAMA,EAAE;QACrD,IAAI,CAACN,cAAc,CAAC,+BAA+B,EAAE,SAAS;MAChE,EAAE,OAAOD,GAAG,EAAE;QACZ,IAAI,CAACC,cAAc,CAAC,0BAA0B,EAAE,QAAQ;MAC1D,UAAU;QACR,IAAI,CAA